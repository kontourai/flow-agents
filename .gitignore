dist/
build/
_site/
test-results/

# Local Flow Agents runtime/session state. Durable source belongs in docs/,
# context/, integrations/, scripts/, or tracked bundle source directories.
.flow-agents/*
.claude/
/.codex/
.ai/
.omx/
.telemetry/
.promptfoo/
.veritas/
.surface/

# Dependency installs and build caches
node_modules/
node_modules
.venv/
__pycache__/
*.py[cod]

# Generated eval output
evals/results/*.json
evals/results/reports/

# OS/editor noise
.DS_Store
*.log
.kontour/

# Local Flow CLI install for source-tree validation (CI recreates it)
.flow-cli/

# Demo recordings are regenerable test outputs (vhs tape / asciinema + prove-teeth) — don't commit the binaries.
# A finalized README/docs gif is committed deliberately under docs/assets/, not the raw evals/acceptance/ output.
evals/acceptance/*.mp4
evals/acceptance/*.gif
