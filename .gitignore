dist/
build/
_site/
test-results/

# Local Flow Agents runtime/session state. Durable source belongs in docs/,
# context/, integrations/, scripts/, or tracked bundle source directories.
.flow-agents/*
.claude/
/.codex/
.ai/
.omx/
.telemetry/
.promptfoo/
.veritas/
.surface/

# Dependency installs and build caches
node_modules/
node_modules
.venv/
__pycache__/
*.py[cod]

# Generated eval output
evals/results/*.json
evals/results/reports/

# OS/editor noise
.DS_Store
*.log
.kontour/

# Local Flow CLI install for source-tree validation (CI recreates it)
.flow-cli/

# Demo recordings are regenerable test outputs (vhs tape / asciinema + prove-teeth) — don't commit the binaries.
# A finalized README/docs gif is committed deliberately under docs/assets/, not the raw evals/acceptance/ output.
evals/acceptance/*.mp4
evals/acceptance/*.gif

# delivery/ is intentionally committed — CI trust anchor reads from it.
# The trust-reconcile.yml job reads delivery/trust.bundle (or trust.checkpoint.json)
# to reconcile agent-claimed passes against fresh CI results.
# Phase-1b follow-up: the deliver skill will write here automatically.
# See scripts/ci/trust-reconcile.js and .github/workflows/trust-reconcile.yml.
# Explicitly allow the delivery directory (negation is a no-op here since
# no earlier rule excludes it, but makes the intent unambiguous):
!delivery/
