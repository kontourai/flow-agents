{
  "allowedTools": [
    "read",
    "imageRead",
    "glob",
    "grep",
    "code",
    "ls"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash ~/.flow-agents/scripts/telemetry/telemetry.sh agentSpawn tool-explore-deps",
        "timeout_ms": 5000
      }
    ],
    "postToolUse": [
      {
        "command": "bash ~/.flow-agents/scripts/telemetry/telemetry.sh postToolUse tool-explore-deps",
        "matcher": "*",
        "timeout_ms": 3000
      },
      {
        "command": "node ~/.flow-agents/scripts/hooks/run-hook.js post:edit:accumulator post-edit-accumulator.js standard,strict",
        "matcher": "fs_write",
        "timeout_ms": 5000
      },
      {
        "command": "node ~/.flow-agents/scripts/hooks/run-hook.js post:quality-gate quality-gate.js strict",
        "matcher": "fs_write",
        "timeout_ms": 15000
      }
    ],
    "preToolUse": [
      {
        "command": "bash ~/.flow-agents/scripts/telemetry/telemetry.sh preToolUse tool-explore-deps",
        "matcher": "*",
        "timeout_ms": 3000
      },
      {
        "command": "node ~/.flow-agents/scripts/hooks/run-hook.js pre:config-protection config-protection.js standard,strict",
        "matcher": "fs_write",
        "timeout_ms": 5000
      },
      {
        "command": "node ~/.flow-agents/scripts/hooks/run-hook.js pre:commit-quality pre-commit-quality.js standard,strict",
        "matcher": "execute_bash",
        "timeout_ms": 30000
      }
    ],
    "stop": [
      {
        "command": "bash ~/.flow-agents/scripts/telemetry/telemetry.sh stop tool-explore-deps",
        "timeout_ms": 5000
      },
      {
        "command": "node ~/.flow-agents/scripts/hooks/run-hook.js stop:format-typecheck stop-format-typecheck.js standard,strict",
        "timeout_ms": 300000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "bash ~/.flow-agents/scripts/telemetry/telemetry.sh userPromptSubmit tool-explore-deps",
        "timeout_ms": 5000
      }
    ]
  },
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://~/.kiro/steering/**/*.md",
    "file://~/.flow-agents/context/common/subagents.md",
    "file://~/.flow-agents/context/*.md"
  ],
  "tools": [
    "read",
    "imageRead",
    "glob",
    "grep",
    "code",
    "ls"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": []
    }
  },
  "name": "tool-explore-deps",
  "description": "Delegate to me for Dependency analysis - parses package manifests to identify tech stack and dependencies",
  "prompt": "You are a Dependency Analyzer. Your ONLY job is to identify the tech stack and dependencies of a codebase.\n\n## Task\n1. Find dependency manifests: package.json, requirements.txt, go.mod, Cargo.toml, pom.xml, build.gradle, Gemfile, etc.\n2. Identify primary language(s) and runtime\n3. List key frameworks and libraries\n4. Note dev dependencies and build tools\n5. Flag any outdated or concerning dependencies if obvious\n\n## Output Format\n```\n## Tech Stack\n- **Language(s)**: [primary languages]\n- **Runtime**: [node, python, go, etc.]\n- **Framework**: [express, django, gin, etc.]\n\n## Key Dependencies\n- [dep1] - [what it's for]\n- [dep2] - [what it's for]\n\n## Dev/Build Tools\n- [tool1], [tool2]\n\n## Concerns\n- [any red flags]\n```\n\nBe FAST. Only read manifest files.",
  "model": "kimi-k2.5"
}
