{
  "id": "mixed.runtime",
  "version": "1.0",
  "steps": [
    { "id": "start", "next": "done" },
    { "id": "done", "next": null }
  ],
  "gates": {
    "runtime-gate": {
      "step": "start",
      "expects": [
        {
          "id": "runtime-evidence",
          "kind": "trust.bundle",
          "required": true,
          "description": "Runtime activation evidence exists.",
          "bundle_claim": {
            "claimType": "mixed.runtime.evidence",
            "subjectType": "artifact",
            "accepted_statuses": ["trusted", "accepted"]
          }
        }
      ]
    }
  }
}
