{
  "id": "k1-agent-extension.build",
  "version": "1.0",
  "steps": [
    { "id": "build", "next": "done" },
    { "id": "done", "next": null }
  ],
  "gates": {
    "build-gate": {
      "step": "build",
      "expects": [
        {
          "id": "build-evidence",
          "kind": "trust.bundle",
          "required": true,
          "description": "Build evidence recorded.",
          "bundle_claim": {
            "claimType": "k1.build.evidence",
            "subjectType": "artifact",
            "accepted_statuses": ["trusted", "accepted"]
          }
        }
      ]
    }
  }
}
