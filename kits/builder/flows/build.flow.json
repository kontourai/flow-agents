{
  "id": "builder.build",
  "version": "1.1",
  "phase_map": {
    "pickup": "pull-work",
    "planning": "plan",
    "execution": "execute",
    "verification": "verify",
    "goal_fit": "merge-ready",
    "evidence": "merge-ready",
    "release": "pr-open",
    "learning": "learn"
  },
  "steps": [
    { "id": "pull-work", "next": "design-probe" },
    { "id": "design-probe", "next": "plan" },
    { "id": "plan", "next": "execute" },
    { "id": "execute", "next": "verify" },
    { "id": "verify", "next": "merge-ready" },
    { "id": "merge-ready", "next": "pr-open" },
    { "id": "pr-open", "next": "merge-ready-ci", "uses_flow": "builder.publish-learn" },
    { "id": "merge-ready-ci", "next": "learn", "uses_flow": "builder.publish-learn" },
    { "id": "learn", "next": "done", "uses_flow": "builder.publish-learn" },
    { "id": "done", "next": null }
  ],
  "gates": {
    "pull-work-gate": {
      "step": "pull-work",
      "expects": [
        {
          "id": "selected-work",
          "kind": "trust.bundle",
          "required": true,
          "description": "A ready work item is selected with scope and acceptance context.",
          "bundle_claim": {
            "claimType": "builder.pull-work.selected",
            "subjectType": "work-item",
            "accepted_statuses": [
              "verified"
            ]
          }
        }
      ]
    },
    "design-probe-gate": {
      "step": "design-probe",
      "expects": [
        {
          "id": "pickup-probe-readiness",
          "kind": "trust.bundle",
          "required": true,
          "description": "Pickup Probe evidence is recorded before planning: goal fit and scope, blockers and dependencies, dependency freshness, acceptance criteria quality, provider state, risk, stop-short risks, planning readiness, decisions, unresolved questions, accepted gaps, probe_status, probe_artifact_ref, grouping decision, expected modified files, and conflict risks.",
          "bundle_claim": {
            "claimType": "builder.design-probe.pickup-readiness",
            "subjectType": "work-item",
            "accepted_statuses": [
              "verified"
            ]
          }
        },
        {
          "id": "probe-decisions-or-accepted-gaps",
          "kind": "trust.bundle",
          "required": true,
          "description": "Planning is blocked until pickup Probe decisions are captured in the pull-work or plan handoff artifact, or unresolved questions are explicitly recorded as accepted gaps. Stale broad continuation language after a merge is not sufficient for planning newly selected work.",
          "bundle_claim": {
            "claimType": "builder.design-probe.decisions",
            "subjectType": "decision",
            "accepted_statuses": [
              "verified"
            ]
          }
        }
      ]
    },
    "plan-gate": {
      "step": "plan",
      "expects": [
        {
          "id": "implementation-plan",
          "kind": "trust.bundle",
          "required": true,
          "description": "The implementation plan names files, changes, acceptance evidence, and sequencing.",
          "bundle_claim": {
            "claimType": "builder.plan.implementation",
            "subjectType": "artifact",
            "accepted_statuses": [
              "verified"
            ]
          }
        }
      ]
    },
    "execute-gate": {
      "step": "execute",
      "expects": [
        {
          "id": "implementation-scope",
          "kind": "trust.bundle",
          "required": true,
          "description": "The implementation scope records changed files and excludes unrelated work.",
          "bundle_claim": {
            "claimType": "builder.execute.scope",
            "subjectType": "change",
            "accepted_statuses": [
              "verified"
            ]
          }
        }
      ]
    },
    "verify-gate": {
      "step": "verify",
      "on_route_back": {
        "missing_evidence": "verify",
        "implementation_defect": "execute",
        "plan_gap": "plan",
        "decision_gap": "design-probe",
        "default": "verify"
      },
      "route_back_policy": {
        "max_attempts": 3,
        "on_exceeded": "block"
      },
      "expects": [
        {
          "id": "tests-evidence",
          "kind": "trust.bundle",
          "required": true,
          "description": "Relevant tests or checks have evidence tied to the implemented change.",
          "bundle_claim": {
            "claimType": "builder.verify.tests",
            "subjectType": "flow-step",
            "accepted_statuses": [
              "verified"
            ]
          }
        },
        {
          "id": "policy-compliance",
          "kind": "trust.bundle",
          "required": false,
          "description": "Policy compliance evidence is attached when policy gates apply.",
          "explore_hint": "Use as advisory evidence for scope, security, privacy, release, or repository policy checks.",
          "bundle_claim": {
            "claimType": "builder.verify.policy-compliance",
            "subjectType": "artifact",
            "accepted_statuses": [
              "verified"
            ]
          }
        }
      ]
    },
    "merge-ready-gate": {
      "step": "merge-ready",
      "on_route_back": {
        "missing_evidence": "verify",
        "implementation_defect": "execute",
        "plan_gap": "plan",
        "decision_gap": "design-probe",
        "default": "verify"
      },
      "route_back_policy": {
        "max_attempts": 3,
        "on_exceeded": "block"
      },
      "expects": [
        {
          "id": "merge-readiness",
          "kind": "trust.bundle",
          "required": true,
          "description": "The change is ready for merge review based on scope, evidence, and unresolved risks.",
          "bundle_claim": {
            "claimType": "builder.merge-ready.readiness",
            "subjectType": "change",
            "accepted_statuses": [
              "verified"
            ]
          }
        }
      ]
    }
  }
}
