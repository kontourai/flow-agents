{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://flow-agents.dev/schemas/knowledge/residue.schema.json",
  "title": "Knowledge Promote Residue",
  "description": "Storage-neutral durable residue consumed by the Knowledge Kit promote/distill pipeline. Workflow-sidecar residue keeps its legacy shape; runtime-session residue adds a bounded, redacted transcript projection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionDir",
    "sessionMarkdown",
    "slug",
    "repo",
    "status",
    "phase",
    "planSummary",
    "definitionOfDone",
    "decisions",
    "learnings",
    "evidence",
    "critiqueSummary",
    "transcriptRefs",
    "touchedFiles"
  ],
  "properties": {
    "sessionDir": { "type": "string", "minLength": 1 },
    "sessionMarkdown": { "type": ["string", "null"] },
    "slug": { "type": "string", "minLength": 1 },
    "repo": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "phase": { "type": ["string", "null"] },
    "planSummary": { "type": "string" },
    "definitionOfDone": { "type": "string" },
    "decisions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "learnings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evidence": { "type": ["object", "null"] },
    "critiqueSummary": { "type": ["object", "null"] },
    "transcriptRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "touchedFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source": { "type": "string", "const": "runtime-session" },
    "runtime": { "type": "string", "enum": ["claude-code", "codex"] },
    "transcriptEntries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2000,
      "items": { "$ref": "#/$defs/transcriptEntry" }
    }
  },
  "dependencies": {
    "source": ["runtime", "transcriptEntries"],
    "runtime": ["source", "transcriptEntries"],
    "transcriptEntries": ["source", "runtime"]
  },
  "oneOf": [
    {
      "not": { "required": ["source"] }
    },
    {
      "required": ["source", "runtime", "transcriptEntries"]
    }
  ],
  "$defs": {
    "transcriptEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "kind", "role", "text"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "kind": {
          "type": "string",
          "enum": ["message", "tool-call", "tool-result"]
        },
        "role": {
          "type": "string",
          "enum": ["user", "assistant", "tool"]
        },
        "text": { "type": "string", "minLength": 1, "maxLength": 32768 }
      }
    }
  }
}
