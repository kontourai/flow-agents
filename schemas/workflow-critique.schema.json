{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow-agents.dev/schemas/workflow-critique.schema.json",
  "title": "Flow Agents Workflow Critique",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_slug",
    "status",
    "required",
    "updated_at",
    "critiques"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "task_slug": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "pass", "fail", "not_required"]
    },
    "required": {
      "type": "boolean"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "critiques": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "reviewer", "reviewed_at", "verdict", "summary", "findings"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "reviewer": {
            "type": "string",
            "minLength": 1
          },
          "reviewed_at": {
            "type": "string",
            "format": "date-time"
          },
          "verdict": {
            "type": "string",
            "enum": ["pass", "comment", "fail", "not_verified"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "artifact_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "severity", "status", "description"],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "severity": {
                  "type": "string",
                  "enum": ["critical", "high", "medium", "low", "info"]
                },
                "status": {
                  "type": "string",
                  "enum": ["open", "accepted", "fixed", "deferred", "false_positive"]
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "file_refs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "uniqueItems": true
                },
                "resolution": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
