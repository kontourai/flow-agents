{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow-agents.dev/schemas/workflow-waves.schema.json",
  "title": "Flow Agents Workflow Waves",
  "description": "Fan-out wave manifest for a workflow session. Each wave declares its expected workers (M) before dispatch; every worker lands exactly one terminal status record; the orchestrator reconciles worker_results against expected_workers at wave close and records an explicit 'N of M reported' reconciliation. A worker that never reported is recorded as not_reported — visible data, never silently absorbed. This sidecar is additive: a session without waves.json declares no fan-out and is unaffected.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_slug",
    "waves"
  ],
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "source",
            "command",
            "artifact",
            "provider",
            "external"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "source"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "file",
              "line_start",
              "line_end",
              "excerpt"
            ]
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "artifact"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "allOf": [
              {
                "anyOf": [
                  {
                    "type": "object",
                    "required": [
                      "file"
                    ]
                  },
                  {
                    "type": "object",
                    "required": [
                      "url"
                    ]
                  }
                ]
              },
              {
                "anyOf": [
                  {
                    "type": "object",
                    "required": [
                      "summary"
                    ]
                  },
                  {
                    "type": "object",
                    "required": [
                      "excerpt"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "command"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "anyOf": [
              {
                "type": "object",
                "required": [
                  "excerpt"
                ]
              },
              {
                "type": "object",
                "required": [
                  "summary"
                ]
              },
              {
                "type": "object",
                "required": [
                  "url"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": {
                "enum": [
                  "provider",
                  "external"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "url"
            ]
          }
        }
      ]
    },
    "expected_worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_id",
        "task"
      ],
      "properties": {
        "worker_id": {
          "type": "string",
          "minLength": 1
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "owned_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "worker_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_id",
        "status",
        "summary",
        "recorded_at"
      ],
      "properties": {
        "worker_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "failed",
            "blocked",
            "not_reported"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        }
      }
    },
    "reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "expected_count",
        "reported_count",
        "summary",
        "reconciled_at"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "complete",
            "incomplete"
          ]
        },
        "expected_count": {
          "type": "integer",
          "minimum": 0
        },
        "reported_count": {
          "type": "integer",
          "minimum": 0
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "reconciled_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "wave": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wave_id",
        "step",
        "declared_at",
        "expected_workers"
      ],
      "properties": {
        "wave_id": {
          "type": "string",
          "minLength": 1
        },
        "step": {
          "type": "string",
          "minLength": 1
        },
        "declared_at": {
          "type": "string",
          "format": "date-time"
        },
        "expected_workers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/expected_worker"
          }
        },
        "worker_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/worker_result"
          }
        },
        "reconciliation": {
          "$ref": "#/$defs/reconciliation"
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "task_slug": {
      "type": "string",
      "minLength": 1
    },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/wave"
      }
    }
  }
}
